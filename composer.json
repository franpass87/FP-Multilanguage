{
    "name": "fp/multilanguage",
    "description": "Plugin WordPress per la gestione multilingua avanzata.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^7.4 || ^8.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.2",
        "squizlabs/php_codesniffer": "^3.10",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "wp-coding-standards/wpcs": "^3.1",
        "brain/monkey": "^2.6",
        "php-stubs/wordpress-stubs": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "FPMultilanguage\\": "fp-multilanguage/includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FPMultilanguage\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/phpcs",
        "lint:fix": "vendor/bin/phpcbf",
        "stan": "php -d memory_limit=1G vendor/bin/phpstan analyse",
        "qa": [
            "@lint",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
